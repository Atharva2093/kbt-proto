generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  firebaseUid  String        @unique
  email        String        @unique
  createdAt    DateTime      @default(now())
  company      String?
  imageUrl     String?
  name         String?
  preferences  Json?
  updatedAt    DateTime      @default(now()) @updatedAt
  analyses     Analysis[]
  materials    Material[]
  procurements Procurement[]
  projects     Project[]
  reports      Report[]
}

model Project {
  id            String        @id @default(cuid())
  name          String
  buildingType  String?
  climateZone   String?
  userId        String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  totalHeatLoss Float?
  uValue        Float?
  efficiency    Float?
  wallArea      Float         @default(100)
  analyses      Analysis[]
  procurements  Procurement[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports       Report[]
  layers        WallLayer[]
}

model WallLayer {
  id           String  @id @default(cuid())
  projectId    String
  material     String
  thickness    Float
  conductivity Float
  density      Float?
  order        Int
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Material {
  id           String   @id @default(cuid())
  name         String
  category     String?
  conductivity Float
  density      Float?
  specificHeat Float?
  unitCost     Float?
  isCustom     Boolean  @default(false)
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [userId], references: [id])
}

model Analysis {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  uValue     Float
  rValue     Float
  heatLoss   Float
  efficiency Float
  details    Json?
  optimizedLayers Json?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Procurement {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  items     Json
  totalCost Float
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orderDate DateTime?
  status    String    @default("GENERATED")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  type      String
  url       String?
  createdAt DateTime @default(now())
  data      Json
  status    String   @default("READY")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
