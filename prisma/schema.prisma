generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  firebaseUid  String   @unique
  email        String   @unique
  createdAt    DateTime @default(now())
  projects     Project[]
}

model Project {
  id            String      @id @default(cuid())
  name          String
  buildingType  String?
  climateZone   String?
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Stored analysis results (summary)
  totalHeatLoss Float?
  uValue        Float?
  efficiency    Float?
  
  layers        WallLayer[]
}

model WallLayer {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  material     String
  thickness    Float   // in mm
  conductivity Float   // in W/mK
  density      Float?  // in kg/m3
  order        Int     // for maintaining layer sequence
}
